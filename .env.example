# =============================================================================
# PCG Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.
# =============================================================================

# Required: Absolute path to the folder where DuckDB database files live.
# The folder and database files will be created automatically on first run.
# All DuckDB databases (engagements.duckdb, users.duckdb) are stored here.
#
# Production (J: drive on remote server):
#   DUCKDB_DIR=J:/PCG/data
#
# Local development:
#   DUCKDB_DIR=./data
DUCKDB_DIR=

# Required: Secret key for signing JWT session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters. Never commit this value.
JWT_SECRET=

# Required for db:backup and db:restore scripts.
# Absolute path to the directory where database backups will be stored.
# Should be outside the project directory (e.g., a network drive or dedicated backup folder).
# The 8 most recent weekly backups are kept automatically (~2 months of history).
#
# Example:
#   BACKUP_DIR=J:/PCG/backups
BACKUP_DIR=
