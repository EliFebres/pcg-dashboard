# =============================================================================
# PCG Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.
# =============================================================================

# Required: Absolute path to the DuckDB database file.
# The database file will be created automatically on first run if it does not exist.
#
# Production (J: drive on remote server):
#   DUCKDB_PATH=J:/PCG/data/engagements.duckdb
#
# Local development:
#   DUCKDB_PATH=./data/engagements.duckdb
DUCKDB_PATH=
